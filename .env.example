# ─── Application ────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1

# ─── MongoDB ────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/anpr_db

# ─── JWT ────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_in_production
JWT_REFRESH_EXPIRES_IN=7d

# ─── Encryption ─────────────────────────────────────────
# 32-byte hex key for AES-256-CBC (generate with: openssl rand -hex 32)
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
# 16-byte hex IV (generate with: openssl rand -hex 16)
ENCRYPTION_IV=0123456789abcdef0123456789abcdef

# ─── Redis ──────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TTL=3600

# ─── Rate Limiting ──────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ─── Admin Bootstrap ────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin@123456
ADMIN_PHONE=0000000000

# ─── Logging ────────────────────────────────────────────
LOG_LEVEL=info
LOG_DIR=logs

REDIS_ENABLED=false